const fmtNum = (n: number) => n >= 1000 ? `${(n / 1000).toFixed(1)}k` : String(n);
const scoreColor = (s: number) => s >= 900 ? "#10B981" : s >= 800 ? "#7C3AED" : s >= 700 ? "#F59E0B" : "#6B7280";
